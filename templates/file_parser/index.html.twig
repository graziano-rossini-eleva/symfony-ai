{% extends 'base.html.twig' %}

{% block title %}{{ 'file_parser.page_title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 40px 20px;
    }

    .wrapper {
        width: 100%;
        max-width: 720px;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 24px;
        font-size: .85rem;
        color: #888;
        text-decoration: none;
    }

    .back-link:hover { color: #1a1a2e; }

    h1 {
        font-size: 1.6rem;
        color: #1a1a2e;
        margin-bottom: 6px;
    }

    .subtitle {
        color: #666;
        font-size: .95rem;
        margin-bottom: 32px;
    }

    .card {
        background: #fff;
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        padding: 28px;
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 24px;
    }

    .field { display: flex; flex-direction: column; gap: 7px; }

    label {
        font-size: .9rem;
        font-weight: 600;
        color: #333;
    }

    input[type="file"],
    textarea {
        padding: 10px 14px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: .9rem;
        font-family: inherit;
        outline: none;
        transition: border-color .2s;
        width: 100%;
    }

    input[type="file"] { cursor: pointer; }
    input[type="file"]:focus,
    textarea:focus { border-color: #1a1a2e; }

    textarea { resize: vertical; min-height: 90px; }

    .btn-primary {
        padding: 12px 24px;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .95rem;
        cursor: pointer;
        transition: opacity .2s;
        align-self: flex-start;
    }

    .btn-primary:hover { opacity: .85; }
    .btn-primary:disabled { opacity: .5; cursor: not-allowed; }

    /* Result */
    .result-card {
        background: #fff;
        border: 2px solid #1a1a2e;
        border-radius: 12px;
        padding: 24px;
        display: none;
    }

    .result-card.visible { display: block; }

    .result-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 16px;
    }

    .result-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    .btn-copy {
        padding: 6px 14px;
        background: transparent;
        border: 1px solid #ddd;
        border-radius: 6px;
        font-size: .82rem;
        cursor: pointer;
        color: #666;
        transition: border-color .2s, color .2s;
    }

    .btn-copy:hover { border-color: #1a1a2e; color: #1a1a2e; }

    pre {
        background: #f8f8f8;
        border-radius: 8px;
        padding: 16px;
        font-size: .85rem;
        line-height: 1.6;
        overflow-x: auto;
        white-space: pre-wrap;
        word-break: break-word;
        color: #222;
    }

    /* Loading / error states */
    .status-msg {
        font-size: .9rem;
        padding: 12px 16px;
        border-radius: 8px;
        display: none;
    }

    .status-msg.visible { display: block; }
    .status-msg.loading { background: #f0f4ff; color: #1a1a2e; }
    .status-msg.error   { background: #fdecea; color: #c0392b; border: 1px solid #f5c6cb; }
</style>
{% endblock %}

{% block body %}
<div class="wrapper">
    <a class="back-link" href="{{ path('home') }}">← {{ 'doc_chat.back'|trans }}</a>
    <h1>{{ 'file_parser.title'|trans }}</h1>
    <p class="subtitle">{{ 'file_parser.subtitle'|trans }}</p>

    <form class="card" id="parse-form">
        <input type="hidden" id="csrf-token" value="{{ csrf_token('file_parser') }}" />

        <div class="field">
            <label for="pdf_file">{{ 'file_parser.upload.label'|trans }}</label>
            <input type="file" id="pdf_file" name="pdf_file" accept="application/pdf" required />
        </div>

        <div class="field">
            <label for="prompt">{{ 'file_parser.prompt.label'|trans }}</label>
            <textarea id="prompt" name="prompt" placeholder="{{ 'file_parser.prompt.placeholder'|trans }}" required></textarea>
        </div>

        <button class="btn-primary" type="submit" id="submit-btn">{{ 'file_parser.submit'|trans }}</button>
    </form>

    <div class="status-msg" id="status-msg"></div>

    <div class="result-card" id="result-card">
        <div class="result-header">
            <span class="result-title">{{ 'file_parser.result.title'|trans }}</span>
            <button class="btn-copy" id="copy-btn">{{ 'file_parser.result.copy'|trans }}</button>
        </div>
        <pre id="result-pre"></pre>
    </div>
</div>

<script>
window.FileParser = {
    routes: {
        parse: {{ path('file_parser_parse')|json_encode|raw }},
    },
    i18n: {
        loading:           {{ 'file_parser.loading'|trans|json_encode|raw }},
        copied:            {{ 'file_parser.result.copied'|trans|json_encode|raw }},
        errorUnknown:      {{ 'file_parser.error.unknown'|trans|json_encode|raw }},
        errorFileTooLarge: {{ 'file_parser.error.file_too_large'|trans|json_encode|raw }},
    },
};
</script>
<script src="{{ asset('js/file-parser.js') }}"></script>
{% endblock %}
