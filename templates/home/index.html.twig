{% extends 'base.html.twig' %}

{% block title %}{{ 'home.page_title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .wrapper {
        text-align: center;
        padding: 48px 20px;
        width: 100%;
        max-width: 860px;
    }

    .logo {
        font-size: 2rem;
        margin-bottom: 12px;
    }

    h1 {
        font-size: 1.7rem;
        color: #1a1a2e;
        margin-bottom: 8px;
    }

    .subtitle {
        color: #666;
        font-size: .95rem;
        margin-bottom: 48px;
    }

    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
    }

    .card {
        background: #fff;
        border: 2px solid #e0e0e0;
        border-radius: 14px;
        padding: 28px 24px;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: border-color .2s, box-shadow .2s;
    }

    .card:not(.card--disabled):hover {
        border-color: #1a1a2e;
        box-shadow: 0 4px 16px rgba(0,0,0,.08);
    }

    .card--disabled {
        opacity: .55;
        cursor: default;
    }

    .card-icon { font-size: 1.8rem; }

    .card-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    .card-desc {
        font-size: .88rem;
        color: #666;
        line-height: 1.5;
        flex: 1;
    }

    .badge {
        display: inline-block;
        font-size: .72rem;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 20px;
        background: #f0f0f0;
        color: #888;
        align-self: flex-start;
    }

    .btn-primary {
        display: inline-block;
        padding: 10px 20px;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .88rem;
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        transition: opacity .2s;
        align-self: flex-start;
    }

    .btn-primary:hover { opacity: .85; }

    .mcp-fab {
        position: fixed;
        bottom: 70px;
        right: 28px;
        width: 44px;
        background: #4f46e5;
        border-radius: 50px;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,.22);
        cursor: pointer;
        transition: width .35s ease, border-radius .3s ease;
        z-index: 100;
    }

    .mcp-fab-trigger {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .mcp-fab-trigger-icon { font-size: 1.1rem; line-height: 1; flex-shrink: 0; }

    .mcp-fab-trigger-label {
        font-size: .82rem;
        font-weight: 700;
        color: #fff;
        opacity: 0;
        transition: opacity .2s ease .1s;
        overflow: hidden;
    }

    .mcp-fab-panel {
        max-height: 0;
        overflow: hidden;
        transition: max-height .35s ease, padding .35s ease;
        padding: 0 16px;
    }

    .mcp-fab-panel-title {
        font-size: .92rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 6px;
    }

    .mcp-fab-panel-desc {
        font-size: .78rem;
        color: rgba(255,255,255,.6);
        line-height: 1.5;
        margin-bottom: 14px;
    }

    .mcp-fab:hover {
        width: 300px;
        border-radius: 14px;
    }

    .mcp-fab:hover .mcp-fab-trigger {
        justify-content: flex-start;
        padding: 10px 16px;
    }

    .mcp-fab:hover .mcp-fab-trigger-label {
        opacity: 1;
    }

    .mcp-fab:hover .mcp-fab-panel {
        max-height: 200px;
        padding: 0 16px 16px;
    }

    .btn-secondary {
        display: block;
        padding: 9px 12px;
        background: #fff;
        color: #1a1a2e;
        border: none;
        border-radius: 8px;
        font-size: .78rem;
        font-weight: 700;
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        white-space: nowrap;
        transition: opacity .2s;
    }

    .btn-secondary:hover { opacity: .85; }
</style>
{% endblock %}

{% block body %}
<div class="wrapper">
    <div class="logo">🤖</div>
    <h1>{{ 'home.title'|trans }}</h1>
    <p class="subtitle">{{ 'home.subtitle'|trans }}</p>

    <div class="features">

        <div class="card">
            <div class="card-icon">📄</div>
            <div class="card-title">{{ 'home.feature.doc_chat.title'|trans }}</div>
            <div class="card-desc">{{ 'home.feature.doc_chat.description'|trans }}</div>
            <a class="btn-primary" href="{{ path('doc_chat') }}">{{ 'home.feature.doc_chat.button'|trans }}</a>
        </div>

        <div class="card">
            <div class="card-icon">📂</div>
            <div class="card-title">{{ 'home.feature.file_parser.title'|trans }}</div>
            <div class="card-desc">{{ 'home.feature.file_parser.description'|trans }}</div>
            <a class="btn-primary" href="{{ path('file_parser') }}">{{ 'home.feature.doc_chat.button'|trans }}</a>
        </div>

        <div class="card">
            <div class="card-icon">🗄️</div>
            <div class="card-title">{{ 'home.feature.sql.title'|trans }}</div>
            <div class="card-desc">{{ 'home.feature.sql.description'|trans }}</div>
            <a class="btn-primary" href="{{ path('sql') }}">{{ 'home.feature.doc_chat.button'|trans }}</a>
        </div>

        <div class="card">
            <div class="card-icon">🤖</div>
            <div class="card-title">{{ 'home.feature.advisor.title'|trans }}</div>
            <div class="card-desc">{{ 'home.feature.advisor.description'|trans }}</div>
            <a class="btn-primary" href="{{ path('advisor') }}">{{ 'home.feature.doc_chat.button'|trans }}</a>
        </div>

        <div class="card">
            <div class="card-icon">📊</div>
            <div class="card-title">{{ 'home.feature.report.title'|trans }}</div>
            <div class="card-desc">{{ 'home.feature.report.description'|trans }}</div>
            <a class="btn-primary" href="{{ path('report') }}">{{ 'home.feature.doc_chat.button'|trans }}</a>
        </div>

    </div>

    <div class="mcp-fab">
        <div class="mcp-fab-panel">
            <div class="mcp-fab-panel-title">{{ 'home.mcp.title'|trans }}</div>
            <div class="mcp-fab-panel-desc">{{ 'home.mcp.description'|trans }}</div>
            <a class="btn-secondary" href="{{ path('mcp_config_download') }}" download>{{ 'home.mcp.button'|trans }}</a>
        </div>
        <div class="mcp-fab-trigger">
            <span class="mcp-fab-trigger-icon">🔌</span>
            <span class="mcp-fab-trigger-label">Claude Desktop (MCP)</span>
        </div>
    </div>
</div>
{% endblock %}
