{% extends 'base.html.twig' %}

{% block title %}{{ 'home.page_title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .wrapper {
        text-align: center;
        padding: 48px 20px;
        width: 100%;
        max-width: 860px;
    }

    .logo {
        font-size: 2rem;
        margin-bottom: 12px;
    }

    h1 {
        font-size: 1.7rem;
        color: #1a1a2e;
        margin-bottom: 8px;
    }

    .subtitle {
        color: #666;
        font-size: .95rem;
        margin-bottom: 48px;
    }

    .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
    }

    .card {
        background: #fff;
        border: 2px solid #e0e0e0;
        border-radius: 14px;
        padding: 28px 24px;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: border-color .2s, box-shadow .2s;
    }

    .card:not(.card--disabled):hover {
        border-color: #1a1a2e;
        box-shadow: 0 4px 16px rgba(0,0,0,.08);
    }

    .card--disabled {
        opacity: .55;
        cursor: default;
    }

    .card-icon { font-size: 1.8rem; }

    .card-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1a1a2e;
    }

    .card-desc {
        font-size: .88rem;
        color: #666;
        line-height: 1.5;
        flex: 1;
    }

    .badge {
        display: inline-block;
        font-size: .72rem;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 20px;
        background: #f0f0f0;
        color: #888;
        align-self: flex-start;
    }

    .btn-primary {
        display: inline-block;
        padding: 10px 20px;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .88rem;
        cursor: pointer;
        text-decoration: none;
        text-align: center;
        transition: opacity .2s;
        align-self: flex-start;
    }

    .btn-primary:hover { opacity: .85; }
</style>
{% endblock %}

{% block body %}
<div class="wrapper">
    <div class="logo">🤖</div>
    <h1>{{ 'home.title'|trans }}</h1>
    <p class="subtitle">{{ 'home.subtitle'|trans }}</p>

    <div class="features">

        <div class="card">
            <div class="card-icon">📄</div>
            <div class="card-title">{{ 'home.feature.doc_chat.title'|trans }}</div>
            <div class="card-desc">{{ 'home.feature.doc_chat.description'|trans }}</div>
            <a class="btn-primary" href="{{ path('doc_chat') }}">{{ 'home.feature.doc_chat.button'|trans }}</a>
        </div>

        <div class="card">
            <div class="card-icon">📂</div>
            <div class="card-title">{{ 'home.feature.file_parser.title'|trans }}</div>
            <div class="card-desc">{{ 'home.feature.file_parser.description'|trans }}</div>
            <a class="btn-primary" href="{{ path('file_parser') }}">{{ 'home.feature.doc_chat.button'|trans }}</a>
        </div>

        <div class="card">
            <div class="card-icon">🗄️</div>
            <div class="card-title">{{ 'home.feature.sql.title'|trans }}</div>
            <div class="card-desc">{{ 'home.feature.sql.description'|trans }}</div>
            <a class="btn-primary" href="{{ path('sql') }}">{{ 'home.feature.doc_chat.button'|trans }}</a>
        </div>

    </div>
</div>
{% endblock %}
