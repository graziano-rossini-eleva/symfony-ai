{% extends 'base.html.twig' %}

{% block title %}{{ 'dql.page_title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
    }
    .wrapper { text-align: center; padding: 48px 20px; max-width: 480px; }
    .icon { font-size: 3rem; margin-bottom: 20px; }
    h1 { font-size: 1.5rem; color: #1a1a2e; margin-bottom: 12px; }
    p { color: #888; font-size: .95rem; margin-bottom: 28px; line-height: 1.6; }
    .badge {
        display: inline-block;
        font-size: .8rem;
        font-weight: 600;
        padding: 5px 14px;
        border-radius: 20px;
        background: #f0f0f0;
        color: #888;
        margin-bottom: 28px;
    }
    a { color: #1a1a2e; font-size: .88rem; }
</style>
{% endblock %}

{% block body %}
<div class="wrapper">
    <div class="icon">🗄️</div>
    <h1>{{ 'dql.title'|trans }}</h1>
    <p>{{ 'dql.description'|trans }}</p>
    <div class="badge">{{ 'home.feature.coming_soon'|trans }}</div>
    <br>
    <a href="{{ path('home') }}">← {{ 'doc_chat.back'|trans }}</a>
</div>
{% endblock %}
