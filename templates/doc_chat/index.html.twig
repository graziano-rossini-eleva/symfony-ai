{% extends 'base.html.twig' %}

{% block title %}{{ 'doc_chat.chat.page_title'|trans({'%projectName%': projectName}) }}{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
    }

    .chat-container {
        width: 100%;
        max-width: 760px;
        height: 90vh;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,.1);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .chat-header {
        padding: 18px 24px;
        background: #1a1a2e;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: .3px;
    }

    .chat-header span {
        font-size: .8rem;
        font-weight: 400;
        opacity: .6;
        display: block;
        margin-top: 2px;
    }

    .chat-header a {
        float: right;
        font-size: .8rem;
        font-weight: 400;
        color: rgba(255,255,255,.6);
        text-decoration: none;
        margin-top: 4px;
    }

    .chat-header a:hover { color: #fff; }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .message {
        max-width: 78%;
        padding: 12px 16px;
        border-radius: 12px;
        line-height: 1.55;
        font-size: .92rem;
        white-space: pre-wrap;
    }

    .message.user {
        background: #1a1a2e;
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
    }

    .message.assistant {
        background: #f0f0f0;
        color: #222;
        align-self: flex-start;
        border-bottom-left-radius: 4px;
    }

    .message.typing {
        background: #f0f0f0;
        color: #999;
        align-self: flex-start;
        font-style: italic;
    }

    .email-card {
        align-self: flex-start;
        background: #fff;
        border: 2px solid #1a1a2e;
        border-radius: 12px;
        padding: 18px 20px;
        max-width: 88%;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .email-card p {
        font-size: .9rem;
        color: #333;
        line-height: 1.4;
        margin-bottom: 4px;
    }

    .email-card input {
        padding: 9px 14px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: .9rem;
        outline: none;
        transition: border-color .2s;
        width: 100%;
    }

    .email-card input:focus { border-color: #1a1a2e; }

    .email-card-actions {
        display: flex;
        gap: 8px;
        margin-top: 4px;
    }

    .btn-primary {
        padding: 9px 18px;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .88rem;
        cursor: pointer;
        transition: opacity .2s;
    }

    .btn-primary:disabled { opacity: .5; cursor: not-allowed; }

    .btn-secondary {
        padding: 9px 18px;
        background: transparent;
        color: #666;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: .88rem;
        cursor: pointer;
    }

    .btn-secondary:hover { border-color: #999; color: #333; }

    .email-card .field-error {
        font-size: .8rem;
        color: #c0392b;
        margin-top: -6px;
    }

    .chat-form {
        display: flex;
        gap: 10px;
        padding: 16px 20px;
        border-top: 1px solid #eee;
        background: #fff;
    }

    .chat-form input {
        flex: 1;
        padding: 10px 16px;
        border: 1px solid #ddd;
        border-radius: 24px;
        font-size: .92rem;
        outline: none;
        transition: border-color .2s;
    }

    .chat-form input:focus { border-color: #1a1a2e; }

    .chat-form button {
        padding: 10px 22px;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 24px;
        font-size: .92rem;
        cursor: pointer;
        transition: opacity .2s;
    }

    .chat-form button:disabled {
        opacity: .5;
        cursor: not-allowed;
    }
</style>
{% endblock %}

{% block body %}
<div class="chat-container">
    <div class="chat-header">
        <a href="{{ path('home') }}">{{ 'doc_chat.chat.back'|trans }}</a>
        {{ projectName }}
        <span>{{ 'doc_chat.chat.subtitle'|trans }}</span>
    </div>

    <div class="chat-messages" id="messages">
        <div class="message assistant">{{ 'doc_chat.chat.welcome'|trans({'%projectName%': projectName}) }}</div>
    </div>

    <form class="chat-form" id="chat-form">
        <input type="text" id="user-input" placeholder="{{ 'doc_chat.chat.input.placeholder'|trans }}" autocomplete="off" />
        <button type="submit" id="send-btn">{{ 'doc_chat.chat.send'|trans }}</button>
    </form>
</div>

{#
    Routes and i18n strings are passed through a configuration object so that
    no inline event handlers or fetch URLs need to be embedded in the script
    block — allowing 'unsafe-inline' to be removed from script-src in the CSP.
#}
<script>
window.DocChat = {
    routes: {
        message:   {{ path('doc_chat_message')|json_encode|raw }},
        sendEmail: {{ path('doc_chat_send_email')|json_encode|raw }},
    },
    i18n: {
        errorUnknown:          {{ 'doc_chat.chat.error.unknown'|trans|json_encode|raw }},
        errorConnection:       {{ 'doc_chat.chat.error.connection'|trans|json_encode|raw }},
        emailCardIntro:        {{ 'email_card.intro'|trans|json_encode|raw }},
        emailNamePlaceholder:  {{ 'email_card.name_placeholder'|trans|json_encode|raw }},
        emailEmailPlaceholder: {{ 'email_card.email_placeholder'|trans|json_encode|raw }},
        emailSubmit:           {{ 'email_card.submit'|trans|json_encode|raw }},
        emailSubmitting:       {{ 'email_card.submitting'|trans|json_encode|raw }},
        emailCancel:           {{ 'email_card.cancel'|trans|json_encode|raw }},
        emailCancelMsg:        {{ 'email_card.cancel_message'|trans|json_encode|raw }},
        emailSuccess:          {{ 'email_card.success'|trans|json_encode|raw }},
        emailErrorSend:        {{ 'email_card.error.send'|trans|json_encode|raw }},
        emailErrorConn:        {{ 'email_card.error.connection'|trans|json_encode|raw }},
        emailErrorName:        {{ 'email_card.error.name'|trans|json_encode|raw }},
        emailErrorEmail:       {{ 'email_card.error.email'|trans|json_encode|raw }},
    },
};
</script>
<script src="{{ asset('js/doc-chat.js') }}"></script>
{% endblock %}
