{% extends 'base.html.twig' %}

{% block title %}{{ 'code_chat.page_title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
    }

    .chat-container {
        width: 100%;
        max-width: 760px;
        height: 90vh;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 4px 24px rgba(0,0,0,.1);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .chat-header {
        padding: 18px 24px;
        background: #4f46e5;
        color: #fff;
        font-size: 1rem;
        font-weight: 600;
        letter-spacing: .3px;
    }

    .chat-header span {
        font-size: .8rem;
        font-weight: 400;
        opacity: .7;
        display: block;
        margin-top: 2px;
    }

    .chat-header a {
        float: right;
        font-size: .8rem;
        font-weight: 400;
        color: rgba(255,255,255,.7);
        text-decoration: none;
        margin-top: 4px;
    }

    .chat-header a:hover { color: #fff; }

    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .message {
        max-width: 85%;
        padding: 12px 16px;
        border-radius: 12px;
        line-height: 1.55;
        font-size: .92rem;
    }

    .message.user {
        background: #4f46e5;
        color: #fff;
        align-self: flex-end;
        border-bottom-right-radius: 4px;
    }

    .message.assistant {
        background: #f0f0f0;
        color: #222;
        align-self: flex-start;
        border-bottom-left-radius: 4px;
    }

    .message.assistant pre {
        background: #1e1e2e;
        color: #cdd6f4;
        border-radius: 6px;
        padding: 12px;
        overflow-x: auto;
        font-size: .82rem;
        margin: 8px 0;
    }

    .message.assistant code {
        background: #e0e0e0;
        border-radius: 3px;
        padding: 1px 5px;
        font-size: .85em;
    }

    .message.assistant pre code {
        background: transparent;
        padding: 0;
    }

    .message.typing {
        background: #f0f0f0;
        color: #999;
        align-self: flex-start;
        font-style: italic;
    }

    .chat-form {
        display: flex;
        gap: 10px;
        padding: 16px 20px;
        border-top: 1px solid #eee;
        background: #fff;
    }

    .chat-form input {
        flex: 1;
        padding: 10px 16px;
        border: 1px solid #ddd;
        border-radius: 24px;
        font-size: .92rem;
        outline: none;
        transition: border-color .2s;
    }

    .chat-form input:focus { border-color: #4f46e5; }

    .chat-form button {
        padding: 10px 22px;
        background: #4f46e5;
        color: #fff;
        border: none;
        border-radius: 24px;
        font-size: .92rem;
        cursor: pointer;
        transition: opacity .2s;
    }

    .chat-form button:disabled { opacity: .5; cursor: not-allowed; }
</style>
{% endblock %}

{% block body %}
<div class="chat-container">
    <div class="chat-header">
        <a href="{{ path('home') }}">{{ 'doc_chat.chat.back'|trans }}</a>
        {{ 'code_chat.title'|trans }}
        <span>{{ 'code_chat.subtitle'|trans }}</span>
    </div>

    <div class="chat-messages" id="messages">
        <div class="message assistant">{{ 'code_chat.welcome'|trans }}</div>
    </div>

    <form class="chat-form" id="chat-form">
        <input type="text" id="user-input"
               placeholder="{{ 'code_chat.input.placeholder'|trans }}"
               autocomplete="off" />
        <button type="submit" id="send-btn">{{ 'code_chat.send'|trans }}</button>
    </form>
</div>

<script>
window.CodeChat = {
    routes: {
        message: {{ path('code_chat_message')|json_encode|raw }},
    },
    i18n: {
        errorUnknown:    {{ 'code_chat.error.unknown'|trans|json_encode|raw }},
        errorConnection: {{ 'code_chat.error.connection'|trans|json_encode|raw }},
        typing:          {{ 'code_chat.typing'|trans|json_encode|raw }},
    },
};
</script>
<script src="{{ asset('js/code-chat.js') }}"></script>
{% endblock %}
