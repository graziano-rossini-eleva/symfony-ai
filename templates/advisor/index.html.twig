{% extends 'base.html.twig' %}

{% block title %}{{ 'advisor.page_title'|trans }}{% endblock %}

{% block stylesheets %}
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f5f5f5;
        min-height: 100vh;
        color: #1a1a2e;
    }

    .page {
        max-width: 860px;
        margin: 0 auto;
        padding: 32px 20px 64px;
    }

    .page-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 8px;
    }

    .page-header h1 { font-size: 1.4rem; font-weight: 700; flex: 1; }

    .back-link { font-size: .85rem; color: #666; text-decoration: none; }
    .back-link:hover { color: #1a1a2e; }

    .subtitle {
        font-size: .88rem;
        color: #888;
        margin-bottom: 28px;
        line-height: 1.5;
    }

    /* ── How it works badge ─────────────────────────────── */
    .how-it-works {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 28px;
    }

    .step-badge {
        display: flex;
        align-items: center;
        gap: 8px;
        background: #fff;
        border: 1.5px solid #e0e0e0;
        border-radius: 20px;
        padding: 6px 14px;
        font-size: .78rem;
        color: #555;
    }

    .step-badge .num {
        width: 18px; height: 18px;
        background: #1a1a2e;
        color: #fff;
        border-radius: 50%;
        font-size: .65rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    /* ── Question card ──────────────────────────────────── */
    .question-card {
        background: #fff;
        border: 2px solid #e0e0e0;
        border-radius: 14px;
        padding: 24px;
        margin-bottom: 24px;
    }

    .question-card label {
        display: block;
        font-weight: 600;
        font-size: .9rem;
        margin-bottom: 10px;
    }

    .question-card textarea {
        width: 100%;
        min-height: 90px;
        padding: 12px 14px;
        border: 1.5px solid #d0d0d0;
        border-radius: 8px;
        font-size: .95rem;
        font-family: inherit;
        resize: vertical;
        line-height: 1.5;
        outline: none;
        transition: border-color .2s;
    }

    .question-card textarea:focus { border-color: #1a1a2e; }

    .question-actions {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 14px;
    }

    .char-count { font-size: .78rem; color: #aaa; margin-left: auto; }
    .char-count.over { color: #c0392b; }

    /* ── Example chips ───────────────────────────────────── */
    .examples-label {
        font-size: .78rem;
        font-weight: 600;
        color: #888;
        margin-top: 16px;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: .05em;
    }

    .chips { display: flex; flex-wrap: wrap; gap: 8px; }

    .chip {
        font-size: .78rem;
        padding: 5px 12px;
        border: 1.5px solid #d0d0d0;
        border-radius: 20px;
        background: #fafafa;
        color: #444;
        cursor: pointer;
        transition: background .15s, border-color .15s, color .15s;
        line-height: 1.4;
    }

    .chip:hover { background: #1a1a2e; border-color: #1a1a2e; color: #fff; }

    /* ── Submit button ──────────────────────────────────── */
    .btn-ask {
        padding: 10px 24px;
        background: #1a1a2e;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .9rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity .2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .btn-ask:disabled { opacity: .5; cursor: not-allowed; }
    .btn-ask:not(:disabled):hover { opacity: .85; }

    .spinner {
        width: 16px; height: 16px;
        border: 2px solid rgba(255,255,255,.35);
        border-top-color: #fff;
        border-radius: 50%;
        animation: spin .65s linear infinite;
        display: none;
    }

    .btn-ask.loading .spinner { display: block; }
    .btn-ask.loading .btn-label { display: none; }
    .btn-ask.loading .thinking-label { display: inline; }
    .thinking-label { display: none; }

    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Error ──────────────────────────────────────────── */
    .error-box {
        background: #fff5f5;
        border: 1.5px solid #f5c6c6;
        border-radius: 10px;
        padding: 14px 18px;
        color: #c0392b;
        font-size: .9rem;
        margin-bottom: 24px;
        display: none;
    }

    /* ── Answer card ────────────────────────────────────── */
    .answer-card {
        background: #fff;
        border: 2px solid #e0e0e0;
        border-radius: 14px;
        overflow: hidden;
        display: none;
    }

    .answer-header {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px 20px;
        border-bottom: 1px solid #e8e8e8;
        font-weight: 700;
        font-size: .9rem;
    }

    .answer-body {
        padding: 20px;
        font-size: .92rem;
        line-height: 1.75;
        color: #222;
        white-space: pre-wrap;
        word-break: break-word;
    }
</style>
{% endblock %}

{% block body %}
<div class="page">

    {# ── Header ──────────────────────────────────────────── #}
    <div class="page-header">
        <span style="font-size:1.8rem">🤖</span>
        <h1>{{ 'advisor.title'|trans }}</h1>
        <a class="back-link" href="{{ path('home') }}">← {{ 'doc_chat.back'|trans }}</a>
    </div>
    <p class="subtitle">{{ 'advisor.subtitle'|trans }}</p>

    {# ── How it works ────────────────────────────────────── #}
    <div class="how-it-works">
        <div class="step-badge"><span class="num">1</span>{{ 'advisor.step.1'|trans }}</div>
        <div class="step-badge"><span class="num">2</span>{{ 'advisor.step.2'|trans }}</div>
        <div class="step-badge"><span class="num">3</span>{{ 'advisor.step.3'|trans }}</div>
    </div>

    {# ── Question form ───────────────────────────────────── #}
    <div class="question-card">
        <label for="question">{{ 'advisor.question.label'|trans }}</label>
        <textarea
            id="question"
            maxlength="1000"
            placeholder="{{ 'advisor.question.placeholder'|trans }}"
            autocomplete="off"
            spellcheck="false"
        ></textarea>

        <div class="examples-label">{{ 'advisor.examples.label'|trans }}</div>
        <div class="chips">
            <button class="chip" type="button" data-q="{{ 'advisor.examples.1'|trans }}">{{ 'advisor.examples.1'|trans }}</button>
            <button class="chip" type="button" data-q="{{ 'advisor.examples.2'|trans }}">{{ 'advisor.examples.2'|trans }}</button>
            <button class="chip" type="button" data-q="{{ 'advisor.examples.3'|trans }}">{{ 'advisor.examples.3'|trans }}</button>
            <button class="chip" type="button" data-q="{{ 'advisor.examples.4'|trans }}">{{ 'advisor.examples.4'|trans }}</button>
            <button class="chip" type="button" data-q="{{ 'advisor.examples.5'|trans }}">{{ 'advisor.examples.5'|trans }}</button>
        </div>

        <div class="question-actions">
            <button class="btn-ask" id="ask-btn" type="button">
                <div class="spinner"></div>
                <span class="btn-label">{{ 'advisor.ask'|trans }}</span>
                <span class="thinking-label">{{ 'advisor.thinking'|trans }}</span>
            </button>
            <span class="char-count" id="char-count">0 / 1000</span>
        </div>
    </div>

    {# ── Error ───────────────────────────────────────────── #}
    <div class="error-box" id="error-box"></div>

    {# ── Answer ──────────────────────────────────────────── #}
    <div class="answer-card" id="answer-card">
        <div class="answer-header">
            <span>🤖</span>
            <span>{{ 'advisor.answer.title'|trans }}</span>
        </div>
        <div class="answer-body" id="answer-body"></div>
    </div>

</div>

<script>
(function () {
    'use strict';

    const questionEl = document.getElementById('question');
    const askBtn     = document.getElementById('ask-btn');
    const charCount  = document.getElementById('char-count');
    const errorBox   = document.getElementById('error-box');
    const answerCard = document.getElementById('answer-card');
    const answerBody = document.getElementById('answer-body');

    // ── Char counter ─────────────────────────────────────
    questionEl.addEventListener('input', () => {
        const len = questionEl.value.length;
        charCount.textContent = len + ' / 1000';
        charCount.classList.toggle('over', len >= 1000);
    });

    // ── Enter to submit ──────────────────────────────────
    questionEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); askBtn.click(); }
    });

    // ── Chips ────────────────────────────────────────────
    document.querySelectorAll('.chip').forEach(chip => {
        chip.addEventListener('click', () => {
            questionEl.value = chip.dataset.q;
            questionEl.dispatchEvent(new Event('input'));
            questionEl.focus();
        });
    });

    // ── Submit ───────────────────────────────────────────
    askBtn.addEventListener('click', async () => {
        const question = questionEl.value.trim();
        if (!question) return;

        setLoading(true);
        hideError();
        hideAnswer();

        try {
            const res  = await fetch('{{ path('advisor_ask') }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question }),
            });

            let data;
            try {
                data = await res.json();
            } catch {
                showError('{{ 'advisor.error.unknown'|trans }}');
                return;
            }

            if (!res.ok) {
                showError(data.error ?? '{{ 'advisor.error.unknown'|trans }}');
                return;
            }

            showAnswer(data.answer);
        } catch {
            showError('{{ 'advisor.error.connection'|trans }}');
        } finally {
            setLoading(false);
        }
    });

    function setLoading(on) {
        askBtn.disabled = on;
        askBtn.classList.toggle('loading', on);
    }

    function hideError()  { errorBox.style.display = 'none'; }
    function hideAnswer() { answerCard.style.display = 'none'; }

    function showError(msg) {
        errorBox.textContent  = msg;
        errorBox.style.display = 'block';
    }

    function showAnswer(text) {
        answerBody.textContent  = text;
        answerCard.style.display = 'block';
        answerCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
})();
</script>
{% endblock %}
